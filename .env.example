# Copy this file to .env.local for local development. In production
# (Cloudflare Pages), set the same variable name under Project settings ->
# Environment variables -> Production/Preview (as a Build variable, not a
# Function secret — this value is inlined into the shipped HTML/JS since
# the site is a static export with no server runtime).

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Leave unset to run the site with analytics fully disabled — no error,
# no script injected, no network request.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
